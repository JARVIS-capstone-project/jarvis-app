# Backend that the Vite dev proxy forwards /api/* to (platform-system).
# Override per-developer in a local .env (gitignored).
VITE_API_TARGET=http://localhost:8080

# Base path the frontend uses for platform API calls.
# Keep this as /api so the dev proxy intercepts and forwards it.
VITE_API_BASE_URL=/api

# Backend that the Vite dev proxy forwards /agent/* to (agent-system).
# The proxy strips the /agent prefix before forwarding (agent-system's
# FastAPI mounts routers at /sessions, not /agent/sessions).
VITE_AGENT_TARGET=http://localhost:8000
